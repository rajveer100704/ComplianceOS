# ComplianceOS Environment Configuration Example

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security & Authentication
AUTH_SECRET=your-secure-random-32-byte-secret-key
API_KEY=your-secure-api-key-value
AUTH_PROVIDER=api_key
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
RATE_LIMIT_PER_MINUTE=120

# Databases
DATABASE_URL=sqlite+aiosqlite:///./compliance.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=compliance_regulations

# Workers & Queue
WORKER_POLL_INTERVAL_SEC=2.0
