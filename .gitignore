# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment variables & secrets
.env
.env.local
.env.*.local
config/keys/*.pem
!config/keys/.gitkeep

# Databases & local runtime storage
*.db
*.sqlite3
compliance.db
test.db
storage/*
!storage/__init__.py
!storage/.gitkeep
exports/*
!exports/.gitkeep
scratch/*
!scratch/.gitkeep

# Testing & Coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE & OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
