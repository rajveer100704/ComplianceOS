# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment variables & secrets
.env
.env.local
.env.*.local
config/keys/*.pem
!config/keys/.gitkeep

# Databases & local runtime storage
*.db
*.sqlite3
compliance.db
test.db
storage/uploads/*
storage/exports/*
storage/reports/*
storage/requests/*
storage/indexes/*
storage/benchmark_history/*
!storage/uploads/.gitkeep
!storage/exports/.gitkeep
!storage/reports/.gitkeep
!storage/requests/.gitkeep
!storage/indexes/.gitkeep
!storage/benchmark_history/.gitkeep
!storage/.gitkeep
!storage/__init__.py
exports/*
!exports/.gitkeep
scratch/*
!scratch/.gitkeep

# Testing & Coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE & OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
